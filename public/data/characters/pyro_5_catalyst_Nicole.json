    "命ノ星座": {
        "1": {
            "名前": "「大いに愛されし人の子よ、 恐るることなかれ」",
            "説明": "チーム内にいる自身のフィールド上キャラクターの攻撃が敵に命中した時、追加で特殊な「ミステリウムの影·合性」を発動して敵に攻撃し、そのキャラクターの元素タイプに対応する元素範囲ダメージを与える。ダメージ量は攻撃を命中させたキャラクターの攻撃力の600%分となり、そのキャラクターによるダメージと見なされる。<br>この効果は6秒毎に1回のみ発動可能。",
            "icon_url": "images/characters/pyro_5_catalyst_Nicole/summaryList_1.png",
            "詳細": []
        },
        "2": {
            "名前": "「汝に汝の 行くべき道を示さん」",
            "説明": "元素スキル<span style=\"color:#FFD780FF\">聖言黙示·顕れぬ光</span>の効果が強化される。<span style=\"color:#FFD780FF\">虚己の恵み</span>は追加で攻撃力を300アップさせ（この効果による攻撃力アップは上限には含まれない）、<span style=\"color:#FFD780FF\">聖祝の導き</span>はキャラクターの元素タイプに基づき、周囲の敵の対応する元素耐性を25%ダウンさせる。同じ元素タイプの元素耐性ダウン効果は重ね掛けできない。<br>また、ニコが元素スキル<span style=\"color:#FFD780FF\">聖言黙示·顕れぬ光</span>を発動した時、周囲のフィールド上のキャラクターにも熾光の護りを付与する。",
            "icon_url": "images/characters/pyro_5_catalyst_Nicole/summaryList_2.png",
            "詳細": []
        },
        "3": {
            "名前": "「汝の傍に灯を、 行く手に光を」",
            "説明": "元素スキル<span style=\"color:#FFD780FF\">聖言黙示·顕れぬ光</span>のスキルLv.+3。<br>最大Lv.15まで。",
            "icon_url": "images/characters/pyro_5_catalyst_Nicole/summaryList_3.png",
            "詳細": []
        },
        "4": {
            "名前": "「たとえ汝が 何処へ赴こうとも」",
            "説明": "付近にいるチーム内キャラクターの<span style=\"color:#FFD780FF\">虚己の恵み</span>が<span style=\"color:#FFD780FF\">聖祝の導き</span>に昇格した時、ニコはそのキャラクターに「導きの加護」効果を付与する。継続時間20秒。この効果は、各キャラクター16秒毎に1回のみ獲得可能。<br>「導きの加護」を持つキャラクターの通常攻撃、重撃、落下攻撃、元素スキル、元素爆発が与えるダメージは、ニコの攻撃力の70%分アップする。この効果は8回発動時、または継続時間終了時に解除される。<br>同時に複数の敵に命中した場合は、命中した敵の数に応じて発動回数を消費する。チーム内に「導きの加護」を持つキャラクターが複数人いる場合、それぞれの発動回数は独立してカウントされる。",
            "icon_url": "images/characters/pyro_5_catalyst_Nicole/summaryList_4.png",
            "詳細": []
        },
        "5": {
            "名前": "「汝の傍らより語りかけん」",
            "説明": "元素爆発<span style=\"color:#FFD780FF\">聖言黙示·天路歴程</span>のスキルLv.+3。<br>最大Lv.15まで。",
            "icon_url": "images/characters/pyro_5_catalyst_Nicole/summaryList_5.png",
            "詳細": []
        },
