    "固有天賦": [
        {
            "名前": "さらなる懲罰",
            "説明": "元素爆発<span style=\"color:#FFD780FF\">魔女狩りの時間なのだ！</span>を発動したうえで、「ハンティング」状態にある「魔女を誘う鈴」が敵にダメージを与え、かつそのダメージが敵に拡散反応を起こした場合、敵の前にその拡散反応に基づいて元素変化した<span style=\"color:#FFD780FF\">「災いを狩るハンマー」</span>を生成して叩きつけ、プルーネの攻撃力150%分の対応する元素ダメージを与える。このダメージは元素爆発ダメージと見なされる。",
            "icon_url": "images/characters/anemo_4_catalyst_Prune/talent_4.png",
            "詳細": []
        },
        {
            "名前": "鈴の音とともに",
            "説明": "プルーネが元素変化を起こした<span style=\"color:#FFD780FF\">「災いを狩るハンマー」</span>を敵に命中させると、付近にいるチーム内の他のキャラクターは5秒間継続する「鈴の鼓舞」効果を獲得する。通常攻撃、重撃、落下攻撃、元素スキル、または元素爆発が敵にダメージを与える時、「鈴の鼓舞」を獲得した際のプルーネの攻撃力のうち2000を超えた部分を基準に、そのダメージをアップさせる。攻撃力1につき、ダメージ+0.025%。最大+50%まで。",
            "icon_url": "images/characters/anemo_4_catalyst_Prune/talent_5.png",
            "詳細": []
        },
        {
            "名前": "魔女からの贈り物·魔女狩りの誓い",
            "説明": "<span style=\"color:#FFD780FF\">魔女の課題·反論の題</span>を完了すると、プルーネは<span style=\"color:#FFD780FF\">魔導</span>キャラクターとして扱われるようになる。チームに魔導キャラクターを2名以上編成すると、<span style=\"color:#FFD780FF\">魔導秘儀</span>効果が発動し、魔導キャラクターは強化される。<br><br><span style=\"color:#FFD780FF\">魔導秘儀</span><br>チーム内の「鈴の鼓舞」効果を受けている魔導キャラクターが敵に任意の元素反応を起こした後、プルーネ自身の攻撃力+60%、継続時間5秒。そのキャラクターが起こした元素反応が拡散反応だった場合、プルーネ自身の攻撃力がさらに追加で30%アップする、継続時間5秒。",
            "icon_url": "images/characters/anemo_4_catalyst_Prune/talent_6.png",
            "詳細": []
        },
        {
            "名前": "改造！トンテンカン！",
            "説明": "キャラクター天賦素材を合成する時、10%の確率で同じ地域の異なる天賦素材をランダムで1個獲得できる。追加獲得素材は、合成後に獲得した素材と同ランクになる。",
            "icon_url": "images/characters/anemo_4_catalyst_Prune/talent_7.png",
